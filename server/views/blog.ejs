<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title><%= blog.title %> | <%= appName %></title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <main class="container py-4">
      <article class="article-shell">
        <h1><%= blog.title %></h1>
        <img
          src="<%= blog.coverImageURL || '/images/default.png' %>"
          class="article-cover"
          alt="<%= blog.title %>"
        />
        <pre class="article-body"><%= blog.body %></pre>
      </article>

      <section class="author-row">
        <img src="<%= blog.createdBy.profileImageURL %>" alt="" />
        <span><%= blog.createdBy.fullName %></span>
      </section>

      <section class="comments-section">
      <h2>Comments (<%= comments.length %>)</h2>
      <% if (locals.user) { %>
        <form action="/blog/comment/<%= blog._id %>" method="post">
          <div class="comment-form">
          <input
            type="text"
            name="content"
            class="form-control"
              placeholder="Share a thoughtful comment"
              required
          />
            <button class="btn btn-primary" type="submit">Add</button>
          </div>
        </form>

      <% } %>
        <div class="comment-list">
        <% comments.forEach(comment => { %>
          <div class="comment-item">
            <img src="<%= comment.createdBy.profileImageURL %>" alt="" />
            <div>
              <strong><%= comment.createdBy.fullName %></strong>
              <pre><%= comment.content %></pre>
            </div>
        </div>
        <% }) %>
      </div>
      </section>
    </main>

    <%- include('./partials/scripts') %>
  </body>
</html>
